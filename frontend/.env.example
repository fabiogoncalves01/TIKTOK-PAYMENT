# Variáveis do Firebase (encontradas no Console do Firebase > Settings > General)
# Para testar no Vercel, adicione essas variáveis nas "Environment Variables" do painel de deploy.

VITE_FIREBASE_API_KEY="SUA_API_KEY_AQUI"
VITE_FIREBASE_AUTH_DOMAIN="SEU_AUTH_DOMAIN.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="SEU_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="SEU_STORAGE_BUCKET.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="USERID"
VITE_FIREBASE_APP_ID="APP_ID"
